{
  "id": "baidu",
  "enabledByDefault": true,
  "skills": ["./skills"],
  "providerAuthEnvVars": {
    "baidu": ["BAIDU_API_KEY"]
  },
  "uiHints": {
    "webSearch.apiKey": {
      "label": "Baidu API Key",
      "help": "Baidu Qianfan web search API key (fallback: BAIDU_API_KEY).",
      "sensitive": true,
      "placeholder": "bce-v3/..."
    }
  },
  "contracts": {
    "webSearchProviders": ["baidu"]
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "webSearch": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "apiKey": {
            "type": ["string", "object"]
          }
        }
      }
    }
  }
}
